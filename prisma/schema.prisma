generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  IDEA
  PRE_PRODUCTION
  REHEARSAL
  PERFORMANCE
  ARCHIVED
}

enum RehearsalStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

model User {
  id       String @id @default(cuid())
  name     String
  username String @unique
  password String?
  avatar   String?

  accounts       Account[]
  sessions       Session[]
  memberships    ProjectMember[]
  castings       Casting[]
  attendances    Attendance[]
  lockedScripts  Script[]
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String @id @default(cuid())
  sessionToken String @unique
  userId       String
  expires      DateTime
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      ProjectStatus @default(IDEA)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members      ProjectMember[]
  script       Script?
  characters   Character[]
  castings     Casting[]
  rehearsals   Rehearsal[]
  performances Performance[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  roles     String[]

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Script {
  id             String    @id @default(cuid())
  projectId      String    @unique
  contentJson    Json
  lockedByUserId String?
  lockedAt       DateTime?

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lockedByUser User?   @relation(fields: [lockedByUserId], references: [id], onDelete: SetNull)
  scenes       Scene[]
}

model Scene {
  id          String @id @default(cuid())
  scriptId    String
  orderIndex  Int
  title       String
  setting     String?
  timeOfDay   String?
  summary     String?

  script    Script     @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  dialogues Dialogue[]
  rehearsals RehearsalScene[]
}

model Character {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String?
  age         Int?
  gender      String?
  image       String?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dialogues Dialogue[]
  castings  Casting[]
}

model Dialogue {
  id          String @id @default(cuid())
  sceneId     String
  characterId String
  text        String
  lineOrder   Int

  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Casting {
  id          String @id @default(cuid())
  projectId   String
  characterId String @unique
  actorUserId String

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
}

model Rehearsal {
  id              String          @id @default(cuid())
  projectId       String
  title           String
  dateTime        DateTime
  durationMinutes Int
  status          RehearsalStatus @default(SCHEDULED)

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenes    RehearsalScene[]
  attendances Attendance[]
}

model RehearsalScene {
  rehearsalId String
  sceneId     String

  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@id([rehearsalId, sceneId])
}

model Attendance {
  id          String           @id @default(cuid())
  rehearsalId String
  userId      String
  status      AttendanceStatus

  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rehearsalId, userId])
}

model Performance {
  id         String   @id @default(cuid())
  projectId  String
  dateTime   DateTime
  venue      String
  ticketInfo String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
